# ─────────────────────────────────────────────
# HaxxWorm.io — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Game Loop ─────────────────────────────────
# Physics simulation rate (Hz) — do not exceed 60
TICK_RATE_HZ=60
# Network broadcast rate (Hz) — must be <= TICK_RATE_HZ
BROADCAST_HZ=20

# ── World ─────────────────────────────────────
WORLD_WIDTH=14000
WORLD_HEIGHT=14000
# Max players per arena before matchmaking opens a new one (Stage B)
MAX_PLAYERS_PER_ARENA=50

# ── Assets (Stage B+ — S3 / CDN) ──────────────
# Leave empty for local file serving (v1 default)
# ASSET_BASE_URL=https://assets.haxxworm.io
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=haxxworm-assets

# ── Redis (Stage D) ───────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Database (Stage D — accounts/skins) ───────
# DATABASE_URL=postgresql://user:pass@localhost:5432/haxxworm
